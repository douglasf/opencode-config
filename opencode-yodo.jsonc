{
  // ============================================================================
  // YODO MODE - "You Only Dev Once" Personal Project Profile
  // ============================================================================
  //
  // Philosophy: MAXIMUM developer velocity for personal projects.
  // If it won't destroy your system, nuke your data, or publish secrets,
  // it should just run. No friction.
  //
  // ✅ ALLOWED freely:
  //   - ALL build/run/test commands for any language/framework
  //   - ALL package managers (install, add, remove, publish — it's YOUR project)
  //   - Docker everything (including rm/rmi — containers are ephemeral)
  //   - Git mutations (add, commit, push, merge, rebase, clean)
  //   - File operations (rm, chmod, chown — you own these files)
  //   - Network tools (curl, wget, httpie)
  //   - Process management (kill stale dev servers)
  //   - Kubernetes local dev (apply, delete, exec)
  //   - GitHub CLI (gh) for PRs, issues, etc.
  //   - Homebrew and system package managers
  //
  // ❌ DENIED (truly destructive / irreversible):
  //   - git push --force (rewrite shared history)
  //   - rm -rf / or ~ (nuke filesystem)
  //   - dd, mkfs, fdisk (destroy disks)
  //   - sudo, su (privilege escalation)
  //   - terraform apply/destroy (infra mutations)
  //   - shutdown, reboot, halt
  //
  // 🤔 ASK (might be intentional but worth confirming):
  //   - Cloud CLI mutations (aws, gcloud, az)
  //   - Writing to system paths (/etc, /usr, /var)
  //
  // Usage: Symlink or copy to your project's opencode.jsonc
  // ============================================================================

  "$schema": "https://opencode.ai/config.json",

  // ======================================================================
  // Tool availability
  // ======================================================================
  // NOTE: websearch (Exa AI) requires OPENCODE_ENABLE_EXA=1 env var.
  // This must be set in your *project directory* (not here), since this
  // config is symlinked into repos. See README.md "Enabling Websearch"
  // for direnv setup instructions.
  // ======================================================================
  "tools": {
    "websearch": true,
    "codesearch": true
  },

  // ======================================================================
  // Model configuration - match strict conf models
  // ======================================================================
  "model": "github-copilot/gpt-5-mini",
  "small_model": "github-copilot/gpt-5-mini",

  "agent": {
    // ======================================================================
    // COORDINATION AGENTS - gpt-5.4-mini (fast routing/delegation)
    // ======================================================================
    "orchestrate": {
      "model": "github-copilot/gpt-5-mini",
      "permission": {
        "websearch": "allow"
      }
    },
    "plan": {
      "model": "github-copilot/gpt-5-mini"
    },
    "quick-answer": {
      "model": "github-copilot/gpt-5-mini"
    },

    // ======================================================================
    // HEAVY-LIFTING AGENTS - opus (deep analysis, code writing, investigation)
    // ======================================================================
    // YODO mode: maximum velocity, minimum friction.
    // If it can't destroy your system, it runs without asking.
    // ======================================================================
    "execute": {
      "model": "github-copilot/claude-opus-4.7",
      "permission": {
        // ====================================================================
        // File operations - allow freely within the project
        // ====================================================================
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",

        // ====================================================================
        // Bash permissions - the heart of YOLO mode
        // ====================================================================
        "bash": {
          // Default: ask before running unknown commands
          "*": "ask",

          // ------------------------------------------------------------------
          // Git: everything allowed EXCEPT force-push (history rewriting)
          // Personal project = you own the repo, merge/rebase freely
          // ------------------------------------------------------------------
          "git*": "allow",
          // Force-push rewrites shared history — still dangerous
          "git push --force*": "deny",
          "git push -f*": "deny",
          "git push *--force*": "deny",

          // ------------------------------------------------------------------
          // GitHub CLI: fully allowed (PRs, issues, releases, etc.)
          // ------------------------------------------------------------------
          "gh*": "allow",

          // ------------------------------------------------------------------
          // Docker: everything allowed (containers are ephemeral)
          // ------------------------------------------------------------------
          "docker*": "allow",
          "docker-compose*": "allow",
          // system prune can free lots of space — confirm first
          "docker system prune*": "ask",

          // ------------------------------------------------------------------
          // Package managers: broad wildcards — it's your project
          // Includes install, remove, publish, everything
          // ------------------------------------------------------------------
          "npm*": "allow",
          "npx*": "allow",
          "yarn*": "allow",
          "pnpm*": "allow",
          "bun*": "allow",
          "pip*": "allow",
          "pip3*": "allow",
          "pipx*": "allow",
          "uv*": "allow",
          "poetry*": "allow",
          "pdm*": "allow",
          "cargo*": "allow",
          "go*": "allow",
          "gem*": "allow",
          "bundle*": "allow",
          "composer*": "allow",
          "swift*": "allow",
          "gradle*": "allow",
          "./gradlew*": "allow",
          "mvn*": "allow",
          "./mvnw*": "allow",
          "brew*": "allow",
          "mas*": "allow",

          // ------------------------------------------------------------------
          // Network tools
          // ------------------------------------------------------------------
          "curl*": "allow",
          "wget*": "allow",
          "http*": "allow",
          "ssh*": "allow",
          "scp*": "allow",
          "rsync*": "allow",

          // ------------------------------------------------------------------
          // Build & dev tools / language runtimes
          // ------------------------------------------------------------------
          "make*": "allow",
          "cmake*": "allow",
          "ninja*": "allow",
          "just*": "allow",
          "task*": "allow",
          "tsc*": "allow",
          "node*": "allow",
          "deno*": "allow",
          "python*": "allow",
          "python3*": "allow",
          "ruby*": "allow",
          "perl*": "allow",
          "java*": "allow",
          "javac*": "allow",
          "gcc*": "allow",
          "g++*": "allow",
          "clang*": "allow",
          "rustc*": "allow",
          "dotnet*": "allow",
          "elixir*": "allow",
          "mix*": "allow",
          "erl*": "allow",
          "zig*": "allow",
          "lua*": "allow",
          "R*": "allow",
          "Rscript*": "allow",

          // ------------------------------------------------------------------
          // Testing & quality tools
          // ------------------------------------------------------------------
          "jest*": "allow",
          "vitest*": "allow",
          "pytest*": "allow",
          "mocha*": "allow",
          "rspec*": "allow",
          "phpunit*": "allow",
          "eslint*": "allow",
          "prettier*": "allow",
          "biome*": "allow",
          "black*": "allow",
          "ruff*": "allow",
          "mypy*": "allow",
          "flake8*": "allow",
          "pylint*": "allow",
          "rubocop*": "allow",
          "shellcheck*": "allow",
          "hadolint*": "allow",

          // ------------------------------------------------------------------
          // Common utilities
          // ------------------------------------------------------------------
          "cat*": "allow",
          "head*": "allow",
          "tail*": "allow",
          "less*": "allow",
          "more*": "allow",
          "wc*": "allow",
          "sort*": "allow",
          "uniq*": "allow",
          "diff*": "allow",
          "grep*": "allow",
          "rg*": "allow",
          "ag*": "allow",
          "find*": "allow",
          "fd*": "allow",
          "ls*": "allow",
          "tree*": "allow",
          "pwd*": "allow",
          "which*": "allow",
          "whereis*": "allow",
          "whoami*": "allow",
          "hostname*": "allow",
          "uname*": "allow",
          "date*": "allow",
          "echo*": "allow",
          "printf*": "allow",
          "env*": "allow",
          "printenv*": "allow",
          "file*": "allow",
          "stat*": "allow",
          "du*": "allow",
          "df*": "allow",
          "free*": "allow",
          "top*": "allow",
          "htop*": "allow",
          "ps*": "allow",
          "lsof*": "allow",
          "netstat*": "allow",
          "ss*": "allow",
          "id*": "allow",
          "groups*": "allow",
          "basename*": "allow",
          "dirname*": "allow",
          "realpath*": "allow",
          "readlink*": "allow",
          "md5*": "allow",
          "sha*": "allow",
          "base64*": "allow",
          "jq*": "allow",
          "yq*": "allow",
          "sed*": "allow",
          "awk*": "allow",
          "cut*": "allow",
          "tr*": "allow",
          "xargs*": "allow",
          "tee*": "allow",
          "tar*": "allow",
          "zip*": "allow",
          "unzip*": "allow",
          "gzip*": "allow",
          "gunzip*": "allow",
          "touch*": "allow",
          "mkdir*": "allow",
          "cp*": "allow",
          "mv*": "allow",
          "ln*": "allow",
          "test*": "allow",
          "[ *": "allow",
          "[[ *": "allow",
          "true*": "allow",
          "false*": "allow",
          "nproc*": "allow",
          "sysctl*": "allow",
          "open*": "allow",
          "pbcopy*": "allow",
          "pbpaste*": "allow",
          "watch*": "allow",
          "time*": "allow",
          "timeout*": "allow",
          "chmod*": "allow",
          "chown*": "allow",

          // ------------------------------------------------------------------
          // File removal: allowed freely, EXCEPT nuking root/home
          // ------------------------------------------------------------------
          "rm*": "allow",
          "rm -rf /*": "deny",
          "rm -rf ~*": "deny",
          "rm -fr /*": "deny",
          "rm -fr ~*": "deny",
          "rm -rf $HOME*": "deny",
          "rm -fr $HOME*": "deny",

          // ------------------------------------------------------------------
          // Process management: allowed (killing stale dev servers is routine)
          // ------------------------------------------------------------------
          "kill*": "allow",
          "killall*": "allow",
          "pkill*": "allow",

          // ------------------------------------------------------------------
          // Kubernetes: fully allowed for local dev
          // ------------------------------------------------------------------
          "kubectl*": "allow",
          "helm*": "allow",
          "k9s*": "allow",
          "minikube*": "allow",
          "kind*": "allow",
          "skaffold*": "allow",

          // ------------------------------------------------------------------
          // Cloud CLIs: read-only allowed, mutations ask
          // ------------------------------------------------------------------
          "aws s3 ls*": "allow",
          "aws s3 cp*": "ask",
          "aws sts*": "allow",
          "aws configure list*": "allow",
          "aws*": "ask",

          "gcloud config list*": "allow",
          "gcloud auth list*": "allow",
          "gcloud projects list*": "allow",
          "gcloud*": "ask",

          "az account show*": "allow",
          "az account list*": "allow",
          "az*": "ask",

          "terraform plan*": "allow",
          "terraform validate*": "allow",
          "terraform fmt*": "allow",
          "terraform init*": "allow",
          "terraform apply*": "deny",
          "terraform destroy*": "deny",

          // ------------------------------------------------------------------
          // Dangerous system operations: ALWAYS DENIED
          // ------------------------------------------------------------------
          "chmod 777*": "deny",
          "chmod -R 777*": "deny",
          "mkfs*": "deny",
          "fdisk*": "deny",
          "dd*": "deny",
          "mount*": "deny",
          "umount*": "deny",
          "shutdown*": "deny",
          "reboot*": "deny",
          "halt*": "deny",
          "poweroff*": "deny",
          "init*": "deny",
          "systemctl*": "ask",
          "service*": "ask",
          "launchctl*": "ask",
          "sudo*": "deny",
          "su *": "deny",
          "passwd*": "deny",
          "useradd*": "deny",
          "userdel*": "deny",
          "usermod*": "deny",
          "groupadd*": "deny",
          "visudo*": "deny",
          "crontab*": "ask",
          "iptables*": "deny",
          "nft*": "deny",
          "ufw*": "deny",

          // Prevent writing to sensitive system paths
          "> /etc/*": "deny",
          "tee /etc/*": "deny",
          "> /usr/*": "deny",
          "> /var/*": "deny",
          "> /sys/*": "deny",
          "> /proc/*": "deny"
        },

        // ====================================================================
        // Task delegation
        // ====================================================================
        "task": "allow",

        // ====================================================================
        // Web & search tools
        // ====================================================================
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",

        // ====================================================================
        // Other tools
        // ====================================================================
        "question": "allow",
        "lsp": "allow",
        "skill": "allow",
        "external_directory": {
          "~/**": "allow",
          "/tmp/**": "allow",
          "*": "ask"
        }
      }
    },
    "investigate": {
      "model": "github-copilot/claude-opus-4.7",
      "permission": {
        "external_directory": {
          "~/**": "allow"
        }
      }
    },
    "architect": {
      "model": "github-copilot/claude-opus-4.7"
    },
    "git": {
      "model": "github-copilot/claude-opus-4.7"
    }
  }
}
